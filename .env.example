# Copy to .env and adjust before deploying.
TRAEFIK_GUI_USER=admin
TRAEFIK_GUI_PASSWORD=changeme

# Override path to acme.json as seen from inside this container.
# Needed when traefik.yml stores acme at a path like /acme.json that isn't
# under /etc/traefik (adjust the host-side volume mount to match).
TRAEFIK_ACME_PATH=/etc/traefik/acme.json

# Override path to Traefik access log file (optional; enables Activity view).
# TRAEFIK_ACCESS_LOG_PATH=/var/log/traefik/access.log

# Stream access logs from a Traefik container's stdout via Docker socket (preferred).
# Set to the Traefik container name. Takes priority over TRAEFIK_ACCESS_LOG_PATH.
# TRAEFIK_CONTAINER_NAME=traefik
