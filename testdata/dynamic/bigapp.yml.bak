http:
  routers:
    bigapp:
      rule: "Host(`bigapp.deputy.nl`)"
      entryPoints:
        - websecure
      service: bigapp-svc
      tls:
        certResolver: cf-dns

  services:
    bigapp-svc:
      loadBalancer:
        servers:
          - url: "http://10.1.1.8:80"
        passHostHeader: true
