http:
  serversTransports:
    insecure-skip:
      insecureSkipVerify: true

  routers:
    immich:
      rule: "Host(`immich.deputy.nl`)"
      entryPoints:
        - websecure
      service: immich-svc
      tls:
        certResolver: cf-dns

  services:
    immich-svc:
      loadBalancer:
        serversTransport: insecure-skip
        servers:
          - url: "http://10.1.1.8:2283"
        #passHostHeader: true
